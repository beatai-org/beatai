# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# nested node_modules in per-skill scripts/ (each skill carries its own
# package.json + lock; node_modules is installed locally, never committed)
.claude/skills/**/node_modules/

# testing
/coverage

# production
/build

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# material-pipeline working area: only sub-list/ is durable (cross-day dedup
# source). raw/<slug>/ and output/<date>/ are temporary intermediates that
# publish cleans up — never commit them.
.claude/skills/material-pipeline/materials/raw/
.claude/skills/material-pipeline/materials/output/

temp-article
/out
/public/docs/materials/output/.obsidian/
/public/docs/materials/.obsidian/

# All in-book images live in beatai-assets and are referenced from markdown
# as full jsDelivr URLs. Drop new images straight into the assets repo
# (scripts/lib/assets-repo.mjs publishToAssetsRepo), not under public/docs/.
/public/docs/**/*.png
/public/docs/**/*.jpg
/public/docs/**/*.jpeg
/public/docs/**/*.gif
/public/docs/**/*.webp
/public/docs/**/*.svg
/public/docs/**/*.avif
/public/docs/**/*.bmp
/public/docs/**/*.ico
